pipeline {

    agent any

    environment {
        APP_NAME     = 'todo-frontend'
        ORACLE_HOST  = '155.248.254.15'
        ORACLE_USER  = 'ubuntu'
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                echo "STAGE 1: Checking out source code"
                checkout scm
                sh 'echo "Commit: $(git log --oneline -1)"'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "STAGE 2: Installing dependencies"
                dir('todo-frontend') {
                    sh '''
                        node --version
                        npm --version
                        npm install
                        echo "Dependencies installed"
                    '''
                }
            }
        }

        stage('Security Audit') {
            steps {
                echo "STAGE 3: Security audit"
                dir('todo-frontend') {
                    sh '''
                        npm audit --audit-level=high || true
                        echo "Security audit complete"
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                echo "STAGE 4: Running tests"
                dir('todo-frontend') {
                    sh '''
                        npm test
                        echo "Tests passed"
                    '''
                }
            }
            post {
                success { echo "Tests PASSED" }
                failure { echo "Tests FAILED" }
            }
        }

        stage('Build Production') {
            steps {
                echo "STAGE 5: Building React app"
                dir('todo-frontend') {
                    sh '''
                        npm run build
                        echo "Build complete"
                        ls dist/
                    '''
                }
            }
        }

        stage('Deploy to Production') {
            steps {
                echo "STAGE 6: Deploying to Oracle"
                sshagent(credentials: ['oracle-ssh-key']) {
                    sh '''
                        scp -o StrictHostKeyChecking=no \
                            -r todo-frontend/dist/* \
                            ${ORACLE_USER}@${ORACLE_HOST}:/home/ubuntu/todo-app/frontend-dist/

                        ssh -o StrictHostKeyChecking=no \
                            ${ORACLE_USER}@${ORACLE_HOST} \
                            "cd /home/ubuntu/todo-app && docker compose restart nginx"

                        echo "Deployment complete!"
                    '''
                }
            }
            post {
                success { echo "DEPLOYMENT SUCCESSFUL - Build #${BUILD_NUMBER}" }
                failure { echo "DEPLOYMENT FAILED - Build #${BUILD_NUMBER}" }
            }
        }

        stage('Summary') {
            steps {
                echo "STAGE 7: Summary"
                sh '''
                    echo "Build: ${BUILD_NUMBER}"
                    echo "Live:  http://155.248.254.15"
                '''
            }
        }

    }

    post {
        success { echo "Pipeline completed successfully!" }
        failure { echo "Pipeline FAILED!" }
        always {
            echo "Cleaning up..."
            sh 'docker image prune -f || true'
        }
    }
}