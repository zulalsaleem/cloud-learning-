pipeline {

    // Run on any available agent
    // In our setup: Jenkins master IS the agent
    agent any

    // ─────────────────────────────────────────
    // ENVIRONMENT VARIABLES
    // Available in ALL stages below
    // ─────────────────────────────────────────
    environment {
        APP_NAME     = 'todo-api'
        NODE_VERSION = '20'

        // Image tagged with build number!
        // todo-api:1, todo-api:2, todo-api:3...
        // Each build has unique traceable image!
        DOCKER_IMAGE = "todo-api:${BUILD_NUMBER}"

        ORACLE_HOST  = '155.248.254.15'
        ORACLE_USER  = 'ubuntu'
        APP_DIR      = '/home/ubuntu/todo-app'
    }

    // ─────────────────────────────────────────
    // TRIGGERS — When to automatically run
    // ─────────────────────────────────────────
    triggers {
        // Poll GitHub every 5 minutes
        // H = hash-based timing (spreads load)
        // Backup to webhooks
        pollSCM('H/5 * * * *')
    }

    // ─────────────────────────────────────────
    // OPTIONS — How the pipeline behaves
    // ─────────────────────────────────────────
    options {
        // Kill build after 30 minutes
        // Prevents hung builds wasting resources!
        timeout(time: 30, unit: 'MINUTES')

        // Only keep last 10 builds
        // Saves disk space on server!
        buildDiscarder(logRotator(numToKeepStr: '10'))

        // Don't run two builds simultaneously
        // Prevents race conditions!
        disableConcurrentBuilds()
    }

    // ─────────────────────────────────────────
    // STAGES — The actual work
    // Run sequentially (one after another)
    // ─────────────────────────────────────────
    stages {

        // ─────────────────────────────────────
        // STAGE 1: Get the code
        // ─────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📥 STAGE 1: Checking out source code"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                // checkout scm = use the repo configured in job
                checkout scm

                // Show what we got (great for debugging!)
                sh '''
                    echo "Branch: $(git branch --show-current)"
                    echo "Commit: $(git log --oneline -1)"
                    echo "Author: $(git log --format='%an' -1)"
                    echo "Date:   $(git log --format='%ai' -1)"
                '''
            }
        }

        // ─────────────────────────────────────
        // STAGE 2: Install packages
        // ─────────────────────────────────────
        stage('Install Dependencies') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📦 STAGE 2: Installing dependencies"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                sh '''
                    node --version
                    npm --version
                    npm ci
                    echo "✅ Dependencies installed"
                '''
            }
        }

        // ─────────────────────────────────────
        // STAGE 3: Security check
        // ─────────────────────────────────────
        stage('Security Audit') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🔒 STAGE 3: Security audit"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                sh '''
                    npm audit --audit-level=high || true
                    echo "✅ Security audit complete"
                '''
            }
        }

        // ─────────────────────────────────────
        // STAGE 4: Run tests — THE GATE!
        // If this fails → everything stops!
        // ─────────────────────────────────────
        stage('Run Tests') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🧪 STAGE 4: Running automated tests"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                sh '''
                    export JWT_SECRET=jenkins_test_secret_key
                    export JWT_EXPIRES_IN=1h
                    export NODE_ENV=test

                    npm test

                    echo "✅ All tests passed"
                '''
            }

            // Post steps for THIS stage only
            post {
                success {
                    echo "✅ Tests PASSED — proceeding to build"
                }
                failure {
                    echo "❌ Tests FAILED — blocking deployment"
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 5: Build Docker image
        // Tagged with build number for traceability
        // ─────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🐳 STAGE 5: Building Docker image"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                sh '''
                    docker build -t ${DOCKER_IMAGE} .
                    docker build -t ${APP_NAME}:latest .

                    echo "✅ Docker image built: ${DOCKER_IMAGE}"
                    docker images ${APP_NAME}
                '''
            }
        }

        // ─────────────────────────────────────
        // STAGE 6: Deploy
        // ONLY runs on main branch!
        // ─────────────────────────────────────
        stage('Deploy to Production') {

            // when block = conditional execution!
            // Skip this stage on feature branches!
            when {
                branch 'main'
            }

            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🚀 STAGE 6: Deploying to Oracle Cloud"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                // sshagent = injects SSH key from credentials store
                // Jenkins securely handles the key!
                sshagent(credentials: ['oracle-ssh-key']) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no \
                            ${ORACLE_USER}@${ORACLE_HOST} \
                            bash << DEPLOY_SCRIPT

                            set -e
                            echo "🚀 Deployment starting..."
                            echo "Time: \$(date)"

                            cd ${APP_DIR}

                            echo "📥 Pulling latest code..."
                            git pull origin main

                            echo "🐳 Rebuilding containers..."
                            docker compose up -d --build

                            echo "⏳ Waiting for startup..."
                            sleep 15

                            echo "🔍 Verifying deployment..."
                            HEALTH=\$(curl -sf http://localhost/api/health || echo "FAILED")

                            if echo "\$HEALTH" | grep -q "ok"; then
                                echo "✅ Deployment successful!"
                                docker compose ps
                            else
                                echo "❌ Health check failed!"
                                docker compose logs --tail=20
                                exit 1
                            fi

DEPLOY_SCRIPT
                    '''
                }
            }

            post {
                success {
                    echo "✅ DEPLOYMENT SUCCESSFUL — Build #${BUILD_NUMBER}"
                }
                failure {
                    echo "❌ DEPLOYMENT FAILED — Build #${BUILD_NUMBER}"
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 7: Summary
        // ─────────────────────────────────────
        stage('Summary') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📊 STAGE 7: Build Summary"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                sh '''
                    echo "Build Number: ${BUILD_NUMBER}"
                    echo "Git Branch:   ${GIT_BRANCH}"
                    echo "Git Commit:   ${GIT_COMMIT}"
                    echo "Build URL:    ${BUILD_URL}"
                    echo "Result:       SUCCESS"
                '''
            }
        }
    }

    // ─────────────────────────────────────────
    // POST — Runs after ALL stages complete
    // Regardless of success or failure!
    // ─────────────────────────────────────────
    post {
        success {
            echo "🎉 Pipeline completed successfully!"
        }

        failure {
            echo "💥 Pipeline FAILED! Check logs above."
            echo "Build URL: ${BUILD_URL}"
        }

        unstable {
            echo "⚠️ Pipeline unstable — check warnings"
        }

        always {
            echo "🧹 Cleaning up..."
            // Remove test files
            sh 'rm -f .env .env.test || true'
            // Clean dangling Docker images (saves disk space!)
            sh 'docker image prune -f || true'
        }
    }
}