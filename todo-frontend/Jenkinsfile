pipeline {

    agent any

    environment {
        APP_NAME     = 'todo-api'
        NODE_VERSION = '20'
        DOCKER_IMAGE = "todo-api:${BUILD_NUMBER}"
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        // ─────────────────────────────────────
        // STAGE 1: Get the code
        // ─────────────────────────────────────
        stage('Checkout') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📥 STAGE 1: Checking out source code"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                checkout scm

                sh '''
                    echo "Branch: $(git branch --show-current)"
                    echo "Commit: $(git log --oneline -1)"
                    echo "Author: $(git log --format='%an' -1)"
                    echo "Date:   $(git log --format='%ai' -1)"
                '''
            }
        }

        // ─────────────────────────────────────
        // STAGE 2: Install packages
        // ─────────────────────────────────────
        stage('Install Dependencies') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📦 STAGE 2: Installing dependencies"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                dir('todo-frontend') {
                    sh '''
                        node --version
                        npm --version
                        npm ci
                        echo "✅ Dependencies installed"
                    '''
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 3: Security check
        // ─────────────────────────────────────
        stage('Security Audit') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🔒 STAGE 3: Security audit"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                dir('todo-frontend') {
                    sh '''
                        npm audit --audit-level=high || true
                        echo "✅ Security audit complete"
                    '''
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 4: Run tests
        // ─────────────────────────────────────
        stage('Run Tests') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🧪 STAGE 4: Running automated tests"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                dir('todo-frontend') {
                    sh '''
                        export JWT_SECRET=jenkins_test_secret_key
                        export JWT_EXPIRES_IN=1h
                        export NODE_ENV=test

                        npm test

                        echo "✅ All tests passed"
                    '''
                }
            }

            post {
                success {
                    echo "✅ Tests PASSED — proceeding to build"
                }
                failure {
                    echo "❌ Tests FAILED — blocking deployment"
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 5: Build Docker image
        // ─────────────────────────────────────
        stage('Build Docker Image') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🐳 STAGE 5: Building Docker image"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                dir('todo-frontend') {
                    sh '''
                        docker build -t ${DOCKER_IMAGE} .
                        docker build -t ${APP_NAME}:latest .

                        echo "✅ Docker image built: ${DOCKER_IMAGE}"
                        docker images ${APP_NAME}
                    '''
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 6: Deploy (always runs)
        // Jenkins and Oracle Cloud = same server
        // No SSH needed — run Docker directly!
        // ─────────────────────────────────────
        stage('Deploy to Production') {

            when {
                expression { return true }
            }

            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "🚀 STAGE 6: Deploying to Oracle Cloud"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

                sh '''
                    echo "🛑 Stopping old container (if running)..."
                    docker stop todo-frontend || true
                    docker rm todo-frontend || true

                    echo "🚀 Starting new container..."
                    docker run -d \
                        --name todo-frontend \
                        --restart unless-stopped \
                        -p 80:80 \
                        todo-api:latest

                    echo "⏳ Waiting for startup..."
                    sleep 5

                    echo "🔍 Verifying deployment..."
                    docker ps | grep todo-frontend && echo "✅ Container is running!" || echo "❌ Container not found!"

                    echo "📋 Container logs (last 10 lines):"
                    docker logs todo-frontend --tail=10
                '''
            }

            post {
                success {
                    echo "✅ DEPLOYMENT SUCCESSFUL — Build #${BUILD_NUMBER}"
                    echo "🌐 App is live at: http://155.248.254.15"
                }
                failure {
                    echo "❌ DEPLOYMENT FAILED — Build #${BUILD_NUMBER}"
                }
            }
        }

        // ─────────────────────────────────────
        // STAGE 7: Summary
        // ─────────────────────────────────────
        stage('Summary') {
            steps {
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "📊 STAGE 7: Build Summary"
                echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo "Build Number: ${BUILD_NUMBER}"
                echo "Git Branch:   ${env.GIT_BRANCH}"
                echo "Git Commit:   ${env.GIT_COMMIT}"
                echo "Build URL:    ${env.BUILD_URL}"
                echo "Live URL:     http://155.248.254.15"
                echo "Result:       SUCCESS"
            }
        }
    }

    // ─────────────────────────────────────────
    // POST — Runs after ALL stages complete
    // ─────────────────────────────────────────
    post {
        success {
            echo "🎉 Pipeline completed successfully!"
            echo "🌐 Todo app is live at: http://155.248.254.15"
        }

        failure {
            echo "💥 Pipeline FAILED! Check logs above."
            echo "Build URL: ${env.BUILD_URL}"
        }

        unstable {
            echo "⚠️ Pipeline unstable — check warnings"
        }

        always {
            echo "🧹 Cleaning up..."
            sh 'rm -f .env .env.test || true'
            sh 'docker image prune -f || true'
        }
    }
}